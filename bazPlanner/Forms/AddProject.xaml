<Window x:Class="bazPlanner.Forms.AddProject"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bazPlanner.Forms"
        mc:Ignorable="d"
        Title="Добавить проект" Height="150" Width="250" ResizeMode="NoResize">
    <Grid>
        <TextBox x:Name="textNameProject" Height="30" Width="150" VerticalAlignment="Top" Margin="0,25,0,0"/>
        <Button Height="30" Width="150" VerticalAlignment="Bottom" Margin="0,0,0,25" Click="CreateNewProject">OK!</Button>
    </Grid>
</Window>
