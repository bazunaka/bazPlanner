<Window x:Class="bazPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="bazPlanner-WPF-NETCore" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="0.5*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Menu Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" VerticalContentAlignment="Center">
            <MenuItem Header="Подключиться к БД" Height="30" Click="FormAuth"></MenuItem>
            <MenuItem Header="Menu2"></MenuItem>
            <MenuItem Header="Menu3"></MenuItem>
            <MenuItem Header="Menu4"></MenuItem>
            <MenuItem Header="Menu5"></MenuItem>
            <MenuItem Header="Menu6"></MenuItem>
        </Menu>
        <Label Grid.Column="2" Grid.Row="0" Background="#FFF0F0F0">Unregistered!</Label>
        <ListView Grid.Row="1" Width="200" HorizontalAlignment="Center"/>
        <Label Grid.Column="0" Grid.Row="2" Background="#FFF0F0F0" Name="labelTime"></Label>
    </Grid>
</Window>
