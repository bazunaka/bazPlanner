<Window x:Class="bazPlannerWPF.Create_project"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bazPlannerWPF"
        mc:Ignorable="d"
        Title="Создать проект" Height="140" Width="190">
    <Grid>
        <TextBox Name="textNameProject" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" Text="Имя проекта" VerticalAlignment="Top" Width="120"/>
        <Button  Name="buttonAddProject" Content="Добавить" HorizontalAlignment="Center" Margin="0,50,0,0" VerticalAlignment="Top" Click="AddProject"/>
    </Grid>
</Window>
