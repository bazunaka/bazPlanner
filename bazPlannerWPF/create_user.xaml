<Window x:Class="bazPlannerWPF.create_user"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bazPlannerWPF"
        mc:Ignorable="d"
        Title="create_user" Height="450" Width="800">
    <Grid>
        <Label Name="qwe">Введите имя пользователя:</Label>
        <Label Margin="0,20,0,0" Name="zxc">Введите пароль:</Label>
        <TextBox Height="25" Width="80" VerticalAlignment="Top" Margin="0,0,0,0"  Text="Name" Name="username"/>
        <TextBox Height="25" Width="80" VerticalAlignment="Top" Margin="0,25,0,0" Text="Password" Name="userpswd"/>
        <Button  Height="25" Width="80" VerticalAlignment="Top" Margin="0,50,0,0" Name="okClick" Click="okClick_Click"></Button>
    </Grid>
</Window>
