<Window x:Class="bazPlannerWPF.create_user"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bazPlannerWPF"
        mc:Ignorable="d"
        Title="create_user" Height="250" Width="400">
    <Grid>
        <Label Name="label_username">Введите имя пользователя:</Label>
        <Label Margin="0,20,0,0" Name="label_password">Введите пароль:</Label>
        <TextBox Height="25" Width="80" VerticalAlignment="Top" Margin="0,0,0,0"  Text="Name" Name="username"/>
        <TextBox Height="25" Width="80" VerticalAlignment="Top" Margin="0,25,0,0" Text="Password" Name="userpswd"/>
        <Button  Height="25" VerticalAlignment="Bottom" Margin="0,0,0,10" Name="okClick" Click="Add_to_DB" 
                 Background="#FF3A62B7" BorderBrush="#FF3A62B7" Content="Добавить в БД" Width="150"></Button>
    </Grid>
</Window>
